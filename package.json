{
  "name": "tripo-image-to-glb-studio",
  "version": "1.0.0",
  "description": "A Tripo OpenAPI powered image-to-GLB web studio with a Tripo-like workflow.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"node server/index.js\" \"vite --host 0.0.0.0\"",
    "build": "vite build",
    "start": "node server/index.js",
    "check": "node --check server/index.js && vite --host 127.0.0.1 --help >/dev/null"
  },
  "dependencies": {
    "@google/model-viewer": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=18.17"
  }
}
