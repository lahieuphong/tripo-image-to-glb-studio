# Lấy key tại Tripo Platform rồi dán vào đây. Không đưa key này lên GitHub/public frontend.
TRIPO_API_KEY=tsk_your_real_key_here

# Backend local port. Frontend dev server sẽ proxy /api sang port này.
PORT=8787

# Chỉ bật true khi Tripo trả model URL ở host lạ và /api/asset bị chặn.
# Mặc định false để tránh proxy URL tùy ý.
ALLOW_ANY_ASSET_PROXY=false